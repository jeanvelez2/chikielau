# ============================================
# Chikielau — Environment Variables
# ============================================
# Copy this file to .env for local development:
#   cp .env.example .env
# Then fill in the values below.
# For Vercel deployment, add these in Project Settings → Environment Variables.

# --- Core ---
GMAIL_USER=<email>@gmail.com
GMAIL_APP_PASSWORD=<16-char-app-password>
ADMIN_SECRET=<random-32-hex>
CRON_SECRET=<random-32-hex>

# --- Upstash Redis (auto-detected by @upstash/redis via Redis.fromEnv()) ---
UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<your-token>

# --- Instagram ---
INSTAGRAM_ACCESS_TOKEN=<long-lived-token>
INSTAGRAM_TOKEN_SECRET=<random-32-hex>

# --- Vercel API (for automatic Instagram token refresh) ---
VERCEL_API_TOKEN=<tok_...>
VERCEL_PROJECT_ID=<prj_...>
VERCEL_TEAM_ID=<team_...or-leave-blank>

# --- Optional ---
# Auto-detected from VERCEL_URL on Vercel. Set explicitly for local dev or custom domain.
BASE_URL=http://localhost:3000
