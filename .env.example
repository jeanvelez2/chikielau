# Instagram Basic Display API Configuration
# Get your access token from: https://developers.facebook.com/apps/
# Follow the Instagram Basic Display API setup guide

INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here

# Vercel Cron Job Configuration (for automatic token refresh)
CRON_SECRET=your_random_secret_key_here
VERCEL_API_TOKEN=your_vercel_api_token_here
VERCEL_PROJECT_ID=your_vercel_project_id_here
VERCEL_TEAM_ID=your_vercel_team_id_here_if_applicable

# Manual Token Refresh (optional - for manual refresh endpoint)
INSTAGRAM_TOKEN_SECRET=your_refresh_secret_key_here

# Gmail Configuration for Contact Form
# Use Gmail App Password (not your regular password)
# Generate at: https://myaccount.google.com/apppasswords
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password
